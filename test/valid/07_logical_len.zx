# Logical operators and len test
items = ["one", "two", "three"]
length = len(items)
name = "Zelx"
name_len = len(name)

print("Items len:", length)
print("Name len:", name_len)

# Logical Operators AND/OR/NOT
is_long = (length > 2)
is_zelx = (name == "Zelx")

if is_long and is_zelx {
    print("Match: is long and is zelx!")
} else {
    print("No match 1")
}

if length == 0 or not is_zelx {
    print("No match 2")
} else {
    print("Match: not empty and is zelx!")
}
